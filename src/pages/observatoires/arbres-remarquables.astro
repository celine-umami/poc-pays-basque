---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Arbres Remarquables" description="Visualisation des arbres remarquables — Pays Basque Open Data">

  <!-- Navbar -->
  <nav class="bg-pays-basque-green shadow-md">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 text-white">
        <span class="text-2xl font-bold tracking-tight">Pays Basque</span>
        <span class="text-pays-basque-green-light text-sm font-medium">Open Data</span>
      </a>
      <a
        href="/"
        class="text-white/80 hover:text-white text-sm flex items-center gap-1 transition-colors"
      >
        ← Tous les observatoires
      </a>
    </div>
  </nav>

  <!-- Header observatoire -->
  <header class="bg-gradient-to-br from-emerald-600 to-teal-800 text-white py-14 px-6">
    <div class="max-w-5xl mx-auto">
      <p class="text-emerald-300 text-sm font-semibold uppercase tracking-widest mb-2">Observatoire</p>
      <h1 class="text-4xl font-bold mb-3">🌳 Arbres Remarquables</h1>
      <p class="text-white/75 max-w-xl">
        Espèces, circonférences et répartition géographique des arbres remarquables répertoriés
        sur le territoire.
      </p>
    </div>
  </header>

  <!-- Contenu — Web Components Lit -->
  <main class="max-w-5xl mx-auto px-6 py-12 space-y-12">

    <!-- KPI : Vigilance météo (données contexte ctx + ctx1) -->
    <section>
      <h2 class="text-xl font-bold text-pays-basque-dark mb-6">Agrégations – Vigilance météo</h2>
      <div class="flex flex-wrap gap-4">
        <umami-context
          context="ctx,ctx1"
          ctx-domain="public.opendatasoft.com"
          ctx-dataset="weatherref-france-vigilance-meteo-departement"
          ctx1-domain="public.opendatasoft.com"
          ctx1-dataset="weatherref-france-vigilance-meteo-departement"
        >
          <umami-aggregation context="ctx" field="phenomenon_id" operation="sum"></umami-aggregation>
          <umami-aggregation context="ctx1" field="color_id" operation="sum"></umami-aggregation>
        </umami-context>
      </div>
    </section>

    <!-- Graphique avec filtre : Arbres remarquables de Paris -->
    <section>
      <h2 class="text-xl font-bold text-pays-basque-dark mb-6">
        Circonférence par espèce — Arbres remarquables de Paris
      </h2>
      <div class="bg-white rounded-2xl shadow-md p-6">
        <umami-context
          context="ctx"
          ctx-domain="documentation-resources.opendatasoft.com"
          ctx-dataset="les-arbres-remarquables-de-paris"
        >
          <div class="mb-4">
            <umami-filter context="ctx" field="arrondissement"></umami-filter>
          </div>
          <umami-chart context="ctx" type="line" x="espece" y="circonference_en_cm"></umami-chart>
        </umami-context>
      </div>
    </section>

  </main>

  <!-- Footer -->
  <footer class="bg-pays-basque-dark text-white py-8 mt-8">
    <div class="max-w-6xl mx-auto px-6 text-center text-sm text-white/60">
      © {new Date().getFullYear()} Pays Basque Open Data — Propulsé par Koumoul
    </div>
  </footer>

  <!-- Chargement des Web Components Lit depuis public/components/ -->
  <script type="module" src="/components/umami-context.js" is:inline></script>
  <script type="module" src="/components/umami-aggregation.js" is:inline></script>
  <script type="module" src="/components/umami-filter.js" is:inline></script>
  <script type="module" src="/components/umami-chart.js" is:inline></script>

</Layout>
